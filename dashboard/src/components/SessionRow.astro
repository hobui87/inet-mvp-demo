---
/**
 * SessionRow.astro — Single session row in the sessions list.
 * Layout: 100px date pill | flex-1 title + mode tag | attendees count | linked MVP names.
 * Phase 04 ownership.
 */
import type { Session, MvpManifest } from '~/lib/types';

interface Props {
  session: Session;
  /** Full MVP list to resolve mvpSlugs → names */
  mvps: MvpManifest[];
}

const { session, mvps } = Astro.props;

// Format date as YYYY-MM-DD for URL slug and display
const dateStr = session.date instanceof Date
  ? session.date.toISOString().slice(0, 10)
  : String(session.date).slice(0, 10);

const displayDate = session.date instanceof Date
  ? session.date.toLocaleDateString('vi-VN', { day: '2-digit', month: '2-digit', year: 'numeric' })
  : dateStr;

const modeLabel: Record<string, string> = {
  'demo-day':        'Demo Day',
  'progress-review': 'Progress Review',
};

const modeClass: Record<string, string> = {
  'demo-day':        'mode-demo',
  'progress-review': 'mode-review',
};

// Resolve linked MVP names from slugs
const linkedMvps = session.mvpSlugs
  .map(slug => mvps.find(m => m.slug === slug))
  .filter((m): m is MvpManifest => m !== undefined);

// Determine status: if date > today → upcoming, else done
const today = new Date();
today.setHours(0, 0, 0, 0);
const sessionDate = session.date instanceof Date ? session.date : new Date(session.date);
const isUpcoming = sessionDate > today;
---

<a href={`/sessions/${dateStr}/`} class="session-row" aria-label={`Session ${dateStr}`}>
  <div class="date-pill">
    <span class="date-num">{displayDate}</span>
  </div>

  <div class="session-body">
    <div class="session-top">
      <span class={`mode-tag ${modeClass[session.mode] ?? ''}`}>
        {modeLabel[session.mode] ?? session.mode}
      </span>
      {session.attendees.length > 0 && (
        <span class="attendees" aria-label={`${session.attendees.length} attendees`}>
          {session.attendees.length} người
        </span>
      )}
    </div>

    {linkedMvps.length > 0 && (
      <div class="linked-mvps">
        {linkedMvps.map(m => (
          <span class="mvp-chip">{m.name}</span>
        ))}
      </div>
    )}

    {session.mvpSlugs.length > 0 && linkedMvps.length === 0 && (
      <div class="linked-mvps">
        {session.mvpSlugs.map(slug => (
          <span class="mvp-chip">{slug}</span>
        ))}
      </div>
    )}
  </div>

  <span class={`status-badge ${isUpcoming ? 'status-upcoming' : 'status-done'}`}>
    {isUpcoming ? 'Upcoming' : 'Done'}
  </span>
</a>

<style>
  .session-row {
    display: flex;
    align-items: center;
    gap: var(--space-8pt-2);
    padding: var(--space-8pt-2);
    background: var(--surface-card);
    border: 1px solid var(--surface-border);
    border-radius: var(--radius);
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.15s, border-color 0.15s;
  }

  .session-row:hover {
    box-shadow: var(--shadow);
    border-color: var(--bsg-nl-300);
  }

  /* 100px date pill per mockup spec */
  .date-pill {
    flex-shrink: 0;
    width: 100px;
    background: var(--bsg-nl-100);
    border: 1px solid var(--bsg-nl-200);
    border-radius: var(--radius-sm);
    padding: var(--space-8pt-1);
    text-align: center;
  }

  .date-num {
    font-size: 12px;
    font-weight: 600;
    color: var(--bsg-nl-700); /* 9.25:1 ✓ */
    line-height: 1.3;
  }

  .session-body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .session-top {
    display: flex;
    align-items: center;
    gap: var(--space-8pt-1);
    flex-wrap: wrap;
  }

  .mode-tag {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 600;
  }

  .mode-demo {
    background: #dbeafe; /* blue-100 */
    color: #1e40af;      /* blue-800 — ~6.5:1 ✓ */
  }

  .mode-review {
    background: #f3e8ff; /* purple-100 */
    color: #6b21a8;      /* purple-800 — ~6:1 ✓ */
  }

  .attendees {
    font-size: 11px;
    color: var(--bsg-nl-600); /* 6.35:1 ✓ */
  }

  .linked-mvps {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .mvp-chip {
    display: inline-block;
    padding: 1px 6px;
    background: var(--bsg-nl-100);
    border: 1px solid var(--bsg-nl-200);
    border-radius: 4px;
    font-size: 11px;
    color: var(--bsg-nl-700); /* 9.25:1 ✓ */
  }

  /* Status badge */
  .status-badge {
    flex-shrink: 0;
    padding: 3px 10px;
    border-radius: var(--radius-sm);
    font-size: 11px;
    font-weight: 600;
  }

  .status-upcoming {
    background: #dbeafe;
    color: #1e40af; /* ~6.5:1 ✓ */
  }

  .status-done {
    background: #d1fae5;
    color: #065f46; /* ~7:1 ✓ */
  }

  @media (max-width: 600px) {
    .session-row {
      flex-wrap: wrap;
    }

    .date-pill {
      width: auto;
    }

    .status-badge {
      width: 100%;
      text-align: center;
    }
  }
</style>
