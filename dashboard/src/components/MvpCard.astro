---
// MvpCard.astro — renders MvpManifest (valid → linked card) OR InvalidManifest (→ MvpCardInvalid warning)
import MvpCardInvalid from './MvpCardInvalid.astro';

interface MvpManifest {
  id?: string;
  name: string;
  slug: string;
  status: 'backlog' | 'building' | 'selected' | 'parked' | 'retired';
  created: Date;
  demo_date?: Date;
  owner: string;
  problem: string;
  target_user?: string;
  tech_stack: string[];
  links?: { demo?: string; repo?: string; cover?: string };
  scoring: Array<{ date: string; business: number; strategic: number; ux: number; tech: number; weighted: number; decision?: string }>;
}

interface InvalidManifest {
  __invalid: true;
  slug: string;
  filePath: string;
  errors: string[];
}

interface Props {
  mvp: MvpManifest | InvalidManifest;
}

const { mvp } = Astro.props;
const isInvalid = '__invalid' in mvp;

const STATUS_LABELS: Record<string, string> = {
  backlog: 'Tồn đọng', building: 'Đang build',
  selected: 'Đã chọn', parked: 'Tạm dừng', retired: 'Đã loại',
};

const validMvp = isInvalid ? null : (mvp as MvpManifest);
const latestScore = validMvp?.scoring?.length
  ? validMvp.scoring[validMvp.scoring.length - 1]?.weighted
  : null;

function fmtDate(d: Date | string | undefined) {
  if (!d) return null;
  return String(d).slice(0, 10);
}
---

{isInvalid
  ? <MvpCardInvalid mvp={mvp as InvalidManifest} />
  : (
    <a href={`/mvp/${validMvp!.slug}/`} class="mvp-card">
      <div class="cover-placeholder" aria-hidden="true"></div>
      <div class="card-body">
        {validMvp!.id && <span class="mvp-id">{validMvp!.id}</span>}
        <h3 class="mvp-name">{validMvp!.name}</h3>
        <div class="card-meta">
          <span class={`badge badge--${validMvp!.status}`}>
            {STATUS_LABELS[validMvp!.status] ?? validMvp!.status}
          </span>
          {latestScore !== null && (
            <span class="score-chip">{Number(latestScore).toFixed(1)}</span>
          )}
        </div>
        <div class="card-tags">
          {validMvp!.tech_stack.slice(0, 3).map((t) => <span class="tag">{t}</span>)}
        </div>
        {validMvp!.demo_date && (
          <p class="demo-date">Demo: {fmtDate(validMvp!.demo_date)}</p>
        )}
      </div>
    </a>
  )
}

<style>
  .mvp-card {
    border-radius: var(--radius);
    border: 1px solid var(--surface-border);
    background: var(--surface-card);
    overflow: hidden;
    display: block;
    text-decoration: none;
    color: inherit;
    box-shadow: var(--shadow-sm);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .mvp-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow);
    text-decoration: none;
  }

  .cover-placeholder {
    height: 72px;
    background: linear-gradient(135deg, var(--bsg-primary), #0355b5);
  }

  .card-body {
    padding: var(--space-8pt-2);
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .mvp-id {
    font-size: 10px;
    color: var(--bsg-nl-600);
    font-weight: 600;
    letter-spacing: 0.4px;
    text-transform: uppercase;
  }

  .mvp-name {
    font-size: 14px;
    font-weight: 600;
    color: var(--bsg-nl-900);
    margin: 0;
    line-height: 1.3;
  }

  .card-meta { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }

  .score-chip {
    font-size: 11px;
    font-weight: 700;
    background: var(--bsg-nl-100);
    color: var(--bsg-nl-700);
    padding: 1px 6px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--bsg-nl-200);
  }

  .card-tags { display: flex; gap: 4px; flex-wrap: wrap; }

  .tag {
    font-size: 10px;
    background: var(--bsg-nl-100);
    color: var(--bsg-nl-700);
    border-radius: 4px;
    padding: 2px 6px;
    font-weight: 500;
  }

  .demo-date { font-size: 11px; color: var(--bsg-nl-600); margin: 0; }

  .badge {
    font-size: 11px;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 999px;
    display: inline-block;
  }

  .badge--backlog  { background: var(--badge-bg-backlog);  color: var(--badge-fg-backlog);  }
  .badge--building { background: var(--badge-bg-building); color: var(--badge-fg-building); }
  .badge--selected { background: var(--badge-bg-selected); color: var(--badge-fg-selected); }
  .badge--parked   { background: var(--badge-bg-parked);   color: var(--badge-fg-parked);   }
  .badge--retired  { background: var(--badge-bg-retired);  color: var(--badge-fg-retired);  }
</style>
