---
/**
 * TechBadge.astro — Small chip showing tech name@version
 * Used in MVP cards and detail page tech_stack list.
 * Phase 04 ownership.
 */
interface Props {
  /** e.g. "Next.js@15" or "Postgres" */
  tech: string;
}

const { tech } = Astro.props;

// Parse "name@version" → { name, version? }
const atIdx = tech.lastIndexOf('@');
const hasVersion = atIdx > 0;
const name = hasVersion ? tech.slice(0, atIdx) : tech;
const version = hasVersion ? tech.slice(atIdx + 1) : null;
---

<span class="tech-badge" title={tech}>
  <span class="badge-name">{name}</span>
  {version && <span class="badge-version">@{version}</span>}
</span>

<style>
  .tech-badge {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    padding: var(--space-8pt-1) var(--space-8pt-2);
    background: var(--bsg-nl-100);
    border: 1px solid var(--bsg-nl-200);
    border-radius: 4px;
    font-size: 11px;
    line-height: 1.3;
    white-space: nowrap;
  }

  .badge-name {
    color: var(--bsg-nl-700); /* 9.25:1 — WCAG AA ✓ */
    font-weight: 500;
  }

  .badge-version {
    color: var(--bsg-nl-600); /* 6.35:1 — WCAG AA ✓ */
    font-weight: 400;
  }
</style>
