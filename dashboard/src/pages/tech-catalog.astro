---
/**
 * tech-catalog.astro — Tech Stack Catalog page (/tech-catalog/).
 * Aggregates tech usage across all MVPs, groups by category, renders TechTile grid.
 * Zero JS — static Astro page. Phase 04 ownership; Phase 05 swaps stubs.
 */
import DashboardLayout from '~/layouts/DashboardLayout.astro';
import TechTile from '~/components/TechTile.astro';
import type { TechAggregate } from '~/lib/types';
import { loadMvps } from '~/lib/load-mvps';
import { aggregateTechStack } from '~/lib/aggregate-tech';

const mvps = await loadMvps();
const tech = aggregateTechStack(mvps);

// Category display order: language → framework → database → service → tool
const CATEGORY_ORDER = ['language', 'framework', 'database', 'service', 'tool'] as const;

const categoryLabel: Record<string, string> = {
  language:  'Languages',
  framework: 'Frameworks',
  database:  'Databases',
  service:   'Services',
  tool:      'Tools',
};

type Category = typeof CATEGORY_ORDER[number];

const grouped = new Map<Category, TechAggregate[]>();
for (const cat of CATEGORY_ORDER) {
  grouped.set(cat, []);
}

for (const entry of tech) {
  const cat = entry.category as Category;
  if (grouped.has(cat)) {
    grouped.get(cat)!.push(entry);
  } else {
    grouped.get('tool')!.push(entry);
  }
}

for (const [, entries] of grouped) {
  entries.sort((a, b) => b.count - a.count);
}

const totalTech = tech.length;
const keepCount  = tech.filter(t => (t as any).verdict === 'keep').length;
const trialCount = tech.filter(t => (t as any).verdict === 'trial').length;
const avoidCount = tech.filter(t => (t as any).verdict === 'avoid').length;

const activeCategories = CATEGORY_ORDER.filter(cat => (grouped.get(cat) ?? []).length > 0);
---

<DashboardLayout title="Tech Stack Catalog — iNET Innovation Lab">
  <div class="page-header">
    <div class="header-text">
      <h1 class="page-title">Tech Stack Catalog</h1>
      <p class="page-sub">Cross-MVP aggregate · learnings, verdicts, MVPs using each tech</p>
    </div>
    <div class="stats-bar" aria-label="Tech catalog statistics">
      <div class="stat">
        <span class="stat-val">{totalTech}</span>
        <span class="stat-lbl">Tech Tried</span>
      </div>
      <div class="stat">
        <span class="stat-val keep-val">{keepCount}</span>
        <span class="stat-lbl">Keep</span>
      </div>
      <div class="stat">
        <span class="stat-val trial-val">{trialCount}</span>
        <span class="stat-lbl">Trial</span>
      </div>
      <div class="stat">
        <span class="stat-val avoid-val">{avoidCount}</span>
        <span class="stat-lbl">Avoid</span>
      </div>
    </div>
  </div>

  {activeCategories.length === 0 ? (
    <div class="empty-state">
      <p>
        Chưa có dữ liệu tech stack. Thêm <code>tech_stack</code> vào
        <code>products/*/mvp.yaml</code>.
      </p>
    </div>
  ) : (
    <div class="catalog">
      {activeCategories.map(cat => (
        <section class="category-section" aria-labelledby={`cat-${cat}`}>
          <h2 id={`cat-${cat}`} class="category-heading">
            {categoryLabel[cat] ?? cat}
          </h2>
          <div class="tech-grid">
            {(grouped.get(cat) ?? []).map(entry => (
              <TechTile entry={entry} />
            ))}
          </div>
        </section>
      ))}
    </div>
  )}
</DashboardLayout>

<style>
  .page-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-8pt-3);
    margin-bottom: var(--space-8pt-4);
    flex-wrap: wrap;
  }

  .page-title {
    font-size: 22px;
    font-weight: 700;
    color: var(--bsg-nl-900); /* 16.1:1 ✓ */
    margin: 0 0 4px;
  }

  .page-sub {
    font-size: 13px;
    color: var(--bsg-nl-600); /* 6.35:1 ✓ */
    margin: 0;
  }

  .stats-bar {
    display: flex;
    gap: var(--space-8pt-3);
    flex-wrap: wrap;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .stat-val {
    font-size: 20px;
    font-weight: 700;
    color: var(--bsg-primary); /* 8.88:1 ✓ */
    line-height: 1.2;
  }

  .keep-val  { color: #065f46; } /* green-900 — 7:1 ✓ */
  .trial-val { color: #92400e; } /* amber-900 — 6:1 ✓ */
  .avoid-val { color: #7f1d1d; } /* red-900 — 6.5:1 ✓ */

  .stat-lbl {
    font-size: 11px;
    color: var(--bsg-nl-600); /* 6.35:1 ✓ */
    white-space: nowrap;
  }

  .catalog {
    display: flex;
    flex-direction: column;
    gap: var(--space-8pt-5);
  }

  .category-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-8pt-2);
  }

  .category-heading {
    font-size: 14px;
    font-weight: 700;
    color: var(--bsg-nl-700); /* 9.25:1 ✓ */
    margin: 0;
    padding-bottom: var(--space-8pt-1);
    border-bottom: 2px solid var(--bsg-primary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .tech-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--space-8pt-2);
  }

  .empty-state {
    padding: var(--space-8pt-5);
    text-align: center;
    color: var(--bsg-nl-600); /* 6.35:1 ✓ */
    background: var(--surface-card);
    border: 1px dashed var(--surface-border);
    border-radius: var(--radius);
  }

  .empty-state code {
    background: var(--bsg-nl-200);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 12px;
    color: var(--bsg-nl-700);
  }
</style>
