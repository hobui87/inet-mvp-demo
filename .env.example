# ============================================================
#  Root .env — biến môi trường cấp monorepo
#  Copy file này thành .env rồi điền giá trị thật:
#    cp .env.example .env
#  .env đã được .gitignore — KHÔNG commit giá trị thật.
# ============================================================

# GitHub Personal Access Token dùng cho script mirror push
# (scripts/github-mirror-push-...). Scope: repo. Chỉ cần khi mirror code lên GitHub.
GITHUB_MIRROR_TOKEN=ghp_your_token_here
