# ============================================================
#  domain-reputation (.env) — copy thành .env: cp .env.example .env
#  .env đã được .gitignore — KHÔNG commit giá trị thật.
# ============================================================

# Google Safe Browsing API v5 key — dùng cho blocklist GSB (weight 25).
# Thiếu key → app vẫn chạy nhưng GSB hiển thị badge [no key] (degrade, không lỗi).
# Lấy key tại: https://console.cloud.google.com/ → Safe Browsing API
GOOGLE_SAFE_BROWSING_API_KEY=

# (Tùy chọn) Override port mặc định 9041
# PORT=9041
